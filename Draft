document.getElementById('panelBeenBtn').addEventListener('click', e => toggleMark(e.target.dataset.name, 'been', e.clientX, e.clientY));

function render() {
  const filtered = restaurants.filter(match);
  const grouped = new Map();
  filtered.forEach(r => {
    if (!grouped.has(r.c)) grouped.set(r.c, []);
    grouped.get(r.c).push(r);
  });

  const known = PREFERRED_ORDER.filter(c => grouped.has(c)).map(c => [c, grouped.get(c)]);
  const extra = [...grouped.entries()].filter(([c]) => !PREFERRED_ORDER.includes(c));
  const orderedGroups = [...known, ...extra];

  const sectionsEl = document.getElementById('sections');
  sectionsEl.innerHTML = '';
  renderIndex(orderedGroups);

  let idx = 1;
  orderedGroups.forEach(([cat, items]) => {
    const sec = document.createElement('section');
    sec.className = 'section';
    sec.id = catId(cat);
    sec.innerHTML = `
      <div class="section-head">
        <div class="section-num">${String(idx).padStart(2,'0')} / ${orderedGroups.length}</div>
        <div><h2>${cat}</h2><p class="section-note">${items.length} ${items.length===1?'spot':'spots'} — tap a tile for details.</p></div>
      </div>
      <div class="tile-grid">${items.map(r => tileHTML(r)).join('')}</div>`;
    sectionsEl.appendChild(sec);
    idx++;
  });

  document.getElementById('empty').style.display = filtered.length ? 'none' : 'block';
  document.querySelectorAll('.tile').forEach((t, i) => {
    t.style.animationDelay = Math.min(i * 0.02, 0.3) + 's';
    t.addEventListener('click', e => {
      if (e.target.closest('.tile-action-btn')) return;
      openPanel(restaurants[Number(t.dataset.index)]);
    });
    t.querySelector('.mark-want')?.addEventListener('click', e => {
      e.stopPropagation();
      toggleMark(restaurants[Number(t.dataset.index)].n, 'want', e.clientX, e.clientY);
    });
    t.querySelector('.mark-been')?.addEventListener('click', e => {
      e.stopPropagation();
      toggleMark(restaurants[Number(t.dataset.index)].n, 'been', e.clientX, e.clientY);
    });
  });

  watchSections();
  updateMeta();
  updateScoreboard();
}

function catId(cat) {
  return cat.toLowerCase().replaceAll(' ','-').replaceAll('&','and').replaceAll("'","");
}

function tileHTML(r) {
  const i = restaurants.indexOf(r);
  const num = String(i + 1).padStart(3, '0');
  const transit = tileBullets(r);
  const isUser = userAdded.has(i);
  return `<button class="tile ${beenSet.has(r.n) ? 'is-been' : ''}" data-index="${i}">
    <div class="tile-actions">
      <span class="tile-action-btn mark-want ${wantSet.has(r.n) ? 'on' : ''}" title="Save to wishlist">♥</span>
      <span class="tile-action-btn mark-been ${beenSet.has(r.n) ? 'on' : ''}" title="Been there">✓</span>
    </div>
    <div class="tile-top">
      <span class="tile-num">${num}${isUser ? '<span class="tile-user-badge">✦</span>' : ''}</span>
      <span class="tile-neighborhood">${r.area || ''}</span>
    </div>
    <h3>${r.n}</h3>
    <p>${r.d || ''}</p>
    <div class="tile-bottom-row">
      <div class="tag-row">${(r.tags||[]).slice(0,3).map(t=>`<span class="tag">${t}</span>`).join('')}</div>
      ${transit}
    </div>
  </button>`;
}

function tileBullets(r) {
  const data = TRANSIT[r.n];
  if (!data || !data.stops || !data.stops[0] || !data.stops[0].lines.length) return '';
  const bullets = data.stops[0].lines.slice(0, 3).map(l => {
    const bg = LINE_COLORS[l] || '#555';
    const tc = ['N','Q','R','W'].includes(l) ? '#000' : '#fff';
    return `<span class="mta-bullet mta-bullet-sm" style="background:${bg};color:${tc}">${l}</span>`;
  }).join('');
  return `<div class="tile-transit">${bullets}<span class="tile-transit-walk">${data.stops[0].name} · ${data.stops[0].walk}</span></div>`;
}

function renderIndex(groups) {
  const ci = document.getElementById('chapterIndex');
  const links = groups.map(([cat], i) =>
    `<button class="chapter-link ${i===0?'active':''}" data-target="${catId(cat)}">${String(i+1).padStart(2,'0')} · ${cat}</button>`
  ).join('');
  ci.innerHTML = `<div class="chapter-kicker">Chapters</div>${links}`;
  ci.querySelectorAll('.chapter-link').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = document.getElementById(btn.dataset.target);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
}

function watchSections() {
  if (currentObserver) currentObserver.disconnect();
  const links = [...document.querySelectorAll('.chapter-link')];
  currentObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        links.forEach(l => l.classList.toggle('active', l.dataset.target === entry.target.id));
      }
    });
  }, { rootMargin: '-34% 0px -58% 0px', threshold: 0 });
  document.querySelectorAll('.section').forEach(sec => currentObserver.observe(sec));
}

