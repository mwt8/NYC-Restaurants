<body>
<div class="grain"></div>
<div class="progress" id="progress"></div>
<div class="overlay" id="overlay"></div>
<div class="toast" id="toast"></div>

<!-- ── DETAIL PANEL ── -->
<div class="spin-overlay" id="spinOverlay">
  <div class="spin-card" style="position:relative">
    <button class="spin-close" id="spinClose">×</button>
    <div class="spin-kicker">Tonight's Pick</div>
    <div class="spin-name" id="spinName">—</div>
    <div class="spin-sub" id="spinSub"></div>
    <div class="spin-actions">
      <button class="spin-btn" id="spinAgain">Spin again</button>
      <button class="spin-btn go" id="spinGo">Take me there</button>
    </div>
  </div>
</div>

<aside class="panel" id="panel" aria-hidden="true">
  <button class="panel-close" id="closePanel" aria-label="Close">×</button>
  <div class="panel-scroll">
    <div class="panel-kicker" id="panelKicker"></div>
    <h2 id="panelTitle"></h2>
    <p class="panel-sub" id="panelDesc"></p>
    <div class="panel-tags" id="panelTags"></div>
    <div class="panel-marks">
      <button class="pmark want" id="panelWantBtn">♥ Save for later</button>
      <button class="pmark been" id="panelBeenBtn">✓ Been there</button>
    </div>
    <div class="detail-block">
      <div class="detail-label">Menu Highlights</div>
      <ul class="highlights" id="panelHighlights"></ul>
    </div>
    <div class="detail-block" id="planBlock" style="display:none">
      <div class="detail-label">Plan the Visit</div>
      <div class="plan-rows" id="planRows"></div>
    </div>
    <div class="detail-block" id="transitBlock">
      <div class="detail-label">Getting There</div>
      <div id="transitContent" class="transit-loading">
        <span class="transit-spinner"></span><span>&nbsp;Finding nearest subway…</span>
      </div>
    </div>
    <div class="detail-block">
      <div class="detail-label">Links</div>
      <div class="links">
        <a class="action" id="websiteLink" target="_blank" rel="noopener"><span>Website / Menu</span>↗</a>
        <a class="action" id="directionsLink" target="_blank" rel="noopener"><span>Directions</span>↗</a>
      </div>
    </div>
    <div class="detail-block">
      <div class="detail-label">Map View</div>
      <iframe class="map-frame" id="mapFrame" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      <p class="map-note">Opens Google Maps using restaurant name + NYC address.</p>
    </div>
  </div>
</aside>

<!-- ── ADD/EDIT MODAL ── -->
<div class="modal-bg" id="addModalBg"></div>
<div class="modal" id="addModal">
  <button class="modal-close" id="closeAddModal">×</button>
  <h3 id="modalTitle">Add Restaurant</h3>
  <div class="form-row">
    <label>Restaurant Name</label>
    <input type="text" id="fName" placeholder="e.g. Carbone">
  </div>
  <div class="form-grid">
    <div class="form-row">
      <label>Category</label>
      <select id="fCategory">
        <option value="">— select or type below —</option>
        <option>Favorites</option><option>After Work</option><option>Chef's Counter</option>
        <option>Happy Hour</option><option>Tacos</option><option>Vegan</option>
        <option>Spanish</option><option>Brunch</option><option>Flights</option>
        <option>Ramen and Pho</option><option>Handrolls</option><option>Soul</option>
        <option>Bodegas &amp; Delis</option><option>Korean</option><option>Thai</option>
        <option>Chinese</option><option>Indian</option><option>Mediterranean</option>
        <option>Italian</option><option>Pizza</option><option>Street Carts</option>
        <option>Dessert</option><option>Food Halls</option><option>Chelsea &amp; Highline</option>
        <option>Steakhouse</option><option>Food Events</option>
      </select>
    </div>
    <div class="form-row">
      <label>Custom Category</label>
      <input type="text" id="fCategoryCustom" placeholder="Or type a new category">
    </div>
  </div>
  <div class="form-row">
    <label>Neighborhood / Area</label>
    <input type="text" id="fArea" placeholder="e.g. West Village">
  </div>
  <div class="form-row">
    <label>Description</label>
    <button class="ai-btn" id="aiGenBtn">
      <span id="aiIcon">✦</span>
      <span id="aiBtnText">Generate with AI</span>
    </button>
    <textarea id="fDesc" placeholder="Description auto-generates when you fill Name + Category. Or write your own."></textarea>
    <small id="aiStatus">AI will auto-generate a description when Name and Category are filled in.</small>
  </div>
  <div class="form-row">
    <label>Menu Highlights</label>
    <input type="text" id="fHighlights" placeholder="Dish 1, Dish 2, Dish 3 (comma separated)">
  </div>
  <div class="form-row">
    <label>Tags</label>
    <div class="tag-input-wrap" id="tagWrap">
      <input type="text" id="fTagInput" placeholder="Type tag + Enter">
    </div>
    <small>Press Enter to add each tag.</small>
  </div>
  <div class="form-grid">
    <div class="form-row">
      <label>Best Time to Visit</label>
      <input type="text" id="fPrime" placeholder="e.g. Weekend dinner">
    </div>
    <div class="form-row">
      <label>Reservations</label>
      <input type="text" id="fRez" placeholder="e.g. Required - book on Resy">
    </div>
  </div>
  <div class="form-row">
    <label>Website (optional)</label>
    <input type="url" id="fWebsite" placeholder="https://...">
  </div>
  <div class="modal-footer">
    <button class="tbtn primary" id="saveRestaurantBtn">Save Restaurant</button>
    <button class="tbtn" id="cancelAddBtn">Cancel</button>
  </div>
</div>

<!-- ── THEME MODAL ── -->
<div class="modal-bg" id="themeModalBg"></div>
<div class="modal theme-modal" id="themeModal">
  <button class="modal-close" id="closeThemeModal">×</button>
  <h3>Theme &amp; Colors</h3>
  <div class="theme-grid" id="themeGrid"></div>
  <div class="color-customizer">
    <div class="detail-label" style="margin-bottom:14px">Custom Accent Color</div>
    <div class="color-row">
      <div class="color-field">
        <input type="color" id="customAccent" value="#b08866">
        <label for="customAccent">Accent Color</label>
      </div>
      <div class="color-field">
        <input type="color" id="customBg" value="#f5f6f9">
        <label for="customBg">Background</label>
      </div>
    </div>
    <div class="color-row">
      <div class="color-field">
        <input type="color" id="customInk" value="#15234a">
        <label for="customInk">Text Color</label>
      </div>
      <div class="color-field">
        <input type="color" id="customPaper" value="#ffffff">
        <label for="customPaper">Card Color</label>
      </div>
    </div>
    <button class="tbtn primary" onclick="applyCustomColors()" style="margin-top:8px">Apply Custom Colors</button>
    <button class="tbtn" onclick="resetColors()" style="margin-top:8px;margin-left:8px">Reset</button>
  </div>
</div>

<!-- ── PAGE ── -->
<div class="wrap">
  <header>
    <div>
      <div class="kicker">A Local's Guide</div>
      <h1>Where to Eat<br>in <em>New York</em></h1>
      <p class="lede">A local's guide. Whether you've got a weekend or a week, these are the spots worth your time — sorted by craving, neighborhood, and occasion. Tap any tile for must-orders, directions, and a live map.</p>
    </div>
    <div class="meta-card">
      <div class="meta-title">Guide Dashboard</div>
      <div class="meta-grid">
        <div class="meta-box"><strong id="countSpots">—</strong><span>Spots</span></div>
        <div class="meta-box"><strong id="countCats">—</strong><span>Categories</span></div>
              </div>
      <p class="meta-note">Select a tile for menu highlights, website, directions &amp; live map.</p>
    </div>
  </header>

  <div class="toolbar">
    <div class="toolbar-inner">
      <div class="toolbar-label">Concierge Search</div>
      <div class="search"><input id="searchInput" type="search" placeholder="Search spot, cuisine, area..."></div>
      <button class="tbtn primary" id="tonightBtn" title="Can't decide? Let the guide pick.">
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="1" y="1" width="12" height="12" rx="3"/><circle cx="4.5" cy="4.5" r="1" fill="currentColor"/><circle cx="9.5" cy="9.5" r="1" fill="currentColor"/><circle cx="9.5" cy="4.5" r="1" fill="currentColor"/><circle cx="4.5" cy="9.5" r="1" fill="currentColor"/></svg>
        Tonight's Pick
      </button>
      <button class="tbtn" id="themeBtn">
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="7" cy="7" r="3"/><circle cx="7" cy="7" r="6"/></svg>
        Themes
      </button>
    </div>
    <div class="scoreboard" id="scoreboard">
      <span class="sb-stat">✓ <b id="sbBeen">0</b> been</span>
      <span class="sb-stat">♥ <b id="sbWant">0</b> saved</span>
      <div class="sb-bar"><div class="sb-fill" id="sbFill"></div></div>
      <span class="sb-label" id="sbLabel"></span>
    </div>
    <div class="chips" id="chips"></div>
  </div>

  <div class="guide-layout">
    <nav class="chapter-index" id="chapterIndex" aria-label="Category index">
      <div class="chapter-kicker">Chapters</div>
    </nav>
    <main id="sections"></main>
  </div>
  <div class="empty" id="empty">No matching restaurants. Clear the search or try another filter.</div>

  <footer>
    <span>NYC / A Local's Guide</span>
    <span class="mark">click, inspect, then go</span>
    <span>v.interactive</span>
  </footer>
</div>

