const _mem = {};
const store = {
  get(k){ try { return window.localStorage.getItem(k); } catch(e) { return _mem[k] ?? null; } },
  set(k,v){ try { window.localStorage.setItem(k,v); } catch(e) { _mem[k] = v; } }
};
let beenSet = new Set(JSON.parse(store.get('nycg_been') || '[]'));
let wantSet = new Set(JSON.parse(store.get('nycg_want') || '[]'));
const saveMarks = () => { store.set('nycg_been', JSON.stringify([...beenSet])); store.set('nycg_want', JSON.stringify([...wantSet])); };

const CHIPS = ['All','\u2665 Saved','\u2713 Been','Date Night','Group','Late Night','Michelin','Jazz','Views'];
let activeChip = 'All';

function chipMatch(r) {
  if (activeChip === 'All') return true;
  if (activeChip === '\u2665 Saved') return wantSet.has(r.n);
  if (activeChip === '\u2713 Been') return beenSet.has(r.n);
  return (r.tags || []).includes(activeChip) || r.c === activeChip;
}

function match(r) {
  const term = document.getElementById('searchInput').value.trim().toLowerCase();
  const catOK = activeCategory === 'All' || r.c === activeCategory;
  const text = [r.n, r.c, r.area, r.d, ...(r.tags || []), ...(r.h || [])].join(' ').toLowerCase();
  return catOK && chipMatch(r) && (!term || text.includes(term));
}

