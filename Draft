const SB_LABELS = [[0,"The city's waiting."],[1,'First one down.'],[5,'Building momentum.'],[10,'Double digits. Respect.'],[25,'Quarter of the list. Serious.'],[50,'Half the city conquered.'],[80,'Legend status loading\u2026'],[95,'You own this town.']];
function updateScoreboard() {
  const total = new Set(restaurants.map(r=>r.n)).size;
  const been = beenSet.size, want = wantSet.size;
  document.getElementById('sbBeen').textContent = been;
  document.getElementById('sbWant').textContent = want;
  document.getElementById('sbFill').style.width = Math.min(100, Math.round(been/total*100)) + '%';
  let label = SB_LABELS[0][1];
  SB_LABELS.forEach(([n,l]) => { if (been >= n) label = l; });
  document.getElementById('sbLabel').textContent = label;
}
const MILESTONES = {1:'\ud83c\udf7d First spot logged. The list has begun.',5:'\ud83d\udd25 5 down. You\u2019re moving.',10:'\ud83d\udcaa 10 spots. Double digits.',25:'\ud83c\udfc6 25 conquered. Quarter of the city.',50:'\ud83d\udc51 50. Half the list. Unreal.'};

// ── Confetti ──
function confettiBurst(x, y) {
  const colors = ['#e05b7b','#3d9a6c','#e8b93e','#5b8de0','#b08866'];
  for (let i = 0; i < 14; i++) {
    const b = document.createElement('div');
    b.className = 'confetti-bit';
    b.style.left = x + 'px'; b.style.top = y + 'px';
    b.style.background = colors[i % colors.length];
    const ang = Math.random() * Math.PI * 2, dist = 40 + Math.random() * 70;
    b.style.setProperty('--cx', Math.cos(ang) * dist + 'px');
    b.style.setProperty('--cy', (Math.sin(ang) * dist - 30) + 'px');
    document.body.appendChild(b);
    setTimeout(() => b.remove(), 750);
  }
}

// ── Toggle marks ──
function toggleMark(name, type, x, y) {
  const set = type === 'been' ? beenSet : wantSet;
  const adding = !set.has(name);
  adding ? set.add(name) : set.delete(name);
  if (adding && type === 'been') {
    confettiBurst(x ?? innerWidth/2, y ?? innerHeight/3);
    if (MILESTONES[beenSet.size]) showToast(MILESTONES[beenSet.size], 3200);
    else showToast('\u2713 ' + name + ' \u2014 logged');
    if (wantSet.has(name)) { wantSet.delete(name); }
  } else if (adding) {
    showToast('\u2665 Saved: ' + name);
  }
  saveMarks();
  syncMarkUI(name);
  updateScoreboard();
  if (activeChip === '\u2665 Saved' || activeChip === '\u2713 Been') render();
}
function syncMarkUI(name) {
  document.querySelectorAll('.tile').forEach(t => {
    const r = restaurants[Number(t.dataset.index)];
    if (!r || r.n !== name) return;
    t.classList.toggle('is-been', beenSet.has(name));
    t.querySelector('.mark-want')?.classList.toggle('on', wantSet.has(name));
    t.querySelector('.mark-been')?.classList.toggle('on', beenSet.has(name));
  });
  const pw = document.getElementById('panelWantBtn'), pb = document.getElementById('panelBeenBtn');
  if (pw && pw.dataset.name === name) {
    pw.classList.toggle('on', wantSet.has(name));
    pb.classList.toggle('on', beenSet.has(name));
    pw.textContent = wantSet.has(name) ? '\u2665 Saved' : '\u2665 Save for later';
    pb.textContent = beenSet.has(name) ? '\u2713 Been there' : '\u2713 Mark as been';
  }
}

