const q = str => encodeURIComponent(str);
const placeQuery = r => [r.n, r.area, 'New York NY'].filter(Boolean).join(' ').trim();
const linkFor = (r, type) => type === 'directions'
  ? `https://www.google.com/maps/dir/?api=1&destination=${q(placeQuery(r))}`
  : `https://www.google.com/maps/search/?api=1&query=${q(placeQuery(r))}`;
const mapSrc = r => `https://www.google.com/maps?q=${q(placeQuery(r))}&output=embed`;

function showToast(msg, duration = 2500) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._timer);
  t._timer = setTimeout(() => t.classList.remove('show'), duration);
}

