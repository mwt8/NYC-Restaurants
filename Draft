let activeCategory = 'All';
let currentObserver = null;
let editIndex = -1;
let pendingTags = [];

// Undo stack — each entry is a deep snapshot of { restaurants, userAdded }
const ORIGINAL_SNAPSHOT = JSON.stringify(restaurants.map(r => ({...r})));
const undoStack = []; // stack of prior states
const MAX_UNDO = 50;

function snapshot() {
  return JSON.stringify(restaurants.map(r => ({...r})));
}

function pushUndo() {
  undoStack.push({ state: snapshot(), userAdded: JSON.stringify([...userAdded]) });
  if (undoStack.length > MAX_UNDO) undoStack.shift();
  updateUndoBtn();
}

function updateUndoBtn() {
  const btn = document.getElementById('undoBtn');
  if (btn) btn.disabled = undoStack.length === 0;
}

