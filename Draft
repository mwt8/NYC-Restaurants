let spinPick = null, spinTimer = null;
function spinPool() {
  const pool = restaurants.filter(match);
  return pool.length ? pool : restaurants;
}
function runSpin() {
  const pool = spinPool();
  const nameEl = document.getElementById('spinName'), subEl = document.getElementById('spinSub');
  nameEl.classList.add('rolling'); subEl.textContent = '';
  let ticks = 0, total = 18 + Math.floor(Math.random() * 8);
  clearInterval(spinTimer);
  spinTimer = setInterval(() => {
    ticks++;
    const r = pool[Math.floor(Math.random() * pool.length)];
    nameEl.textContent = r.n;
    if (ticks >= total) {
      clearInterval(spinTimer);
      spinPick = pool[Math.floor(Math.random() * pool.length)];
      nameEl.textContent = spinPick.n;
      nameEl.classList.remove('rolling');
      subEl.textContent = `${spinPick.c} \u00b7 ${spinPick.area}` + (TRANSIT[spinPick.n] ? ` \u00b7 \ud83d\ude87 ${TRANSIT[spinPick.n].stops[0].name}, ${TRANSIT[spinPick.n].stops[0].walk} walk` : '');
    }
  }, 65 + ticks);
}
function openSpin() {
  document.getElementById('spinOverlay').classList.add('open');
  runSpin();
}
document.getElementById('tonightBtn').addEventListener('click', openSpin);
document.getElementById('spinAgain').addEventListener('click', runSpin);
document.getElementById('spinClose').addEventListener('click', () => { clearInterval(spinTimer); document.getElementById('spinOverlay').classList.remove('open'); });
document.getElementById('spinOverlay').addEventListener('click', e => { if (e.target.id === 'spinOverlay') { clearInterval(spinTimer); e.target.classList.remove('open'); } });
document.getElementById('spinGo').addEventListener('click', () => {
